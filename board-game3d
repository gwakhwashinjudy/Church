<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>🎲 우리들의 대화 보드게임</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: { level1: '#FF8A8A', level2: '#4ADE80', level3: '#A78BFA' }
                }
            }
        }
    </script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/gh/orioncactus/pretendard@v1.3.9/dist/web/static/pretendard.css" />
    <style>
        body { font-family: 'Pretendard', sans-serif; background-color: #0b0c10; overflow: hidden; }
        .glass { background: rgba(255, 255, 255, 0.03); backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px); border: 1px solid rgba(255, 255, 255, 0.08); }
        .break-keep { word-break: keep-all; }
        .scene { width: 60px; height: 60px; perspective: 300px; margin: 10px auto; }
        .cube { width: 100%; height: 100%; position: relative; transform-style: preserve-3d; transition: transform 0.1s linear; }
        .cube__face { position: absolute; width: 60px; height: 60px; background: #fff; border: 2px solid #ccc; border-radius: 12px; display: flex; align-items: center; justify-content: center; font-size: 24px; font-weight: 900; color: #000; box-shadow: inset 0 0 10px rgba(0,0,0,0.2), 0 0 10px rgba(255,255,255,0.1); }
        .cube__face--1 { transform: rotateY(0deg) translateZ(30px); color: #e11d48; font-size: 30px; }
        .cube__face--6 { transform: rotateY(180deg) translateZ(30px); }
        .cube__face--3 { transform: rotateY(90deg) translateZ(30px); }
        .cube__face--4 { transform: rotateY(-90deg) translateZ(30px); }
        .cube__face--2 { transform: rotateX(90deg) translateZ(30px); }
        .cube__face--5 { transform: rotateX(-90deg) translateZ(30px); }
        @keyframes rollingAnimation { 0% { transform: rotateX(0deg) rotateY(0deg) rotateZ(0deg); } 100% { transform: rotateX(720deg) rotateY(1080deg) rotateZ(360deg); } }
        .is-rolling { animation: rollingAnimation 0.8s cubic-bezier(0.2, 0.8, 0.2, 1) infinite; }
        .show-1 { transform: rotateX(0deg) rotateY(0deg); }
        .show-6 { transform: rotateX(0deg) rotateY(180deg); }
        .show-3 { transform: rotateX(0deg) rotateY(-90deg); }
        .show-4 { transform: rotateX(0deg) rotateY(90deg); }
        .show-2 { transform: rotateX(-90deg) rotateY(0deg); }
        .show-5 { transform: rotateX(90deg) rotateY(0deg); }
        @keyframes miniJump { 0%, 100% { transform: translateY(0); } 50% { transform: translateY(-6px); } }
        .piece-active { animation: miniJump 0.6s ease infinite; }
    </style>
</head>
<body class="text-white min-h-screen flex flex-col justify-between p-3 md:p-5 select-none">

    <header class="w-full max-w-5xl mx-auto flex justify-between items-center mb-2">
