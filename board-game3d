        const l3Descs = ["마음 판에 새겨진 말씀이 내 상황에 어떻게 위로를 주었나요?", "세상 모임과 다르게 우리 소그룹에서만 느끼는 안도감.", "성경 인물의 뚝심이나 순종 중 탐나는 매력.", "인자한 미소, 격려 등 주님이 나를 보시는 눈빛 상상.", "혼자 앓지 않고 지체들이 기도의 힘을 모으고픈 제목.", "모태신앙에서 깨어나거나 뜨겁게 거듭났던 인생의 터닝포인트.", "우연을 가장해 내 필요를 정확히 채우신 최근 은혜.", "서로를 향한 세심한 관찰을 담은 아낌없는 리스펙.", "10년 뒤 나는 공동체의 어떤 든든한 선배가 될까?", "전성기 대비 지금 내 영적 갈급함이나 평안함 수치.", "지나온 삶의 깊은 골짜기에서 주님이 동행해 주신 사연.", "건강, 동역자 등 주님이 거저 주신 위대한 자산.", "교리가 아닌 내 삶 속에서 예수님은 어떤 분이신가요?", "세상 속에서 소금과 빛으로 살아가며 겪는 분투기.", "나 스스로에게 채점해 보는 영적 루틴 상태.", "성경을 읽거나 신앙생활 중 생긴 솔직한 궁금증.", "보이지 않는 곳에서 소그룹원들을 섬기는 즐거운 상상.", "주님이 내게 주신 고유한 재능을 공동체에 녹여내는 법.", "커피 한 잔, 따뜻한 문자 등 사랑을 흘려보낸 기억.", "건물을 넘어 우리 소그룹이 주는 영적 고향의 온기.", "낙심에 빠졌을 때 나를 골방으로 이끄는 하나님의 장치.", "큐티나 설교를 통해 새롭게 다가온 주님의 성품.", "예수님 중심의 가정을 세워나가는 아름다운 청사진.", "성공, 신앙, 가정 등 내 에너지가 쏠리는 진짜 순위.", "먼 훗날 주님 품에 처음 안길 때 던질 첫마디.", "예배 시간 사수 등 주님 앞에 세울 은밀한 다짐.", "십자가 사랑이 내 마음에 진짜로 믿어지기 시작한 날.", "우측 지체의 기도제목을 듣고 전하는 진심 어린 축복.", "내 이정표가 되어주는 단 하나의 평생 말씀 구절.", "내 뜻과 달랐으나 완벽한 때에 길을 여셨던 증거.", "신앙 선배의 궤적을 보며 잠자던 믿음에 불이 붙은 일.", "인간적 서운함을 기도의 골방에서 은혜로 덮어낸 간증.", "날마다 자기를 부인하며 좁은 길을 묵묵히 걸어가는 태도."];

        for(let i=0; i<100; i++) {
            if(i<35) QUESTIONS_POOL.push({ id:i+1, level:1, icon:'🎈', title:l1Titles[i], desc:l1Descs[i] });
            else if(i<68) QUESTIONS_POOL.push({ id:i+1, level:2, icon:'🌱', title:l2Titles[i-35], desc:l2Descs[i-35] });
            else QUESTIONS_POOL.push({ id:i+1, level:3, icon:'✨', title:l3Titles[i-68], desc:l3Descs[i-68] });
        }

        const rows = 5; const cols = 6; const totalGameTiles = 30; let tokenPosition = 0;

        function buildSnakeBoard() {
            const gridContainer = document.getElementById('board-grid'); gridContainer.innerHTML = '';
            let boardLayout = Array.from(Array(rows), () => Array(cols).fill(null)); let currentNum = 1;

            for (let r = 0; r < rows; r++) {
                if (r % 2 === 0) { for (let c = 0; c < cols; c++) { if (currentNum <= totalGameTiles) boardLayout[r][c] = currentNum++; } }
                else { for (let c = cols - 1; c >= 0; c--) { if (currentNum <= totalGameTiles) boardLayout[r][c] = currentNum++; } }
            }

            for (let r = 0; r < rows; r++) {
                for (let c = 0; c < cols; c++) {
                    const tileNum = boardLayout[r][c]; const cell = document.createElement('div');
                    if (tileNum === null) { cell.className = "opacity-0"; }
                    else if (tileNum === 1) {
                        cell.id = `tile-0`; cell.setAttribute('onclick', `clickTile(0)`);
                        cell.className = "bg-amber-500 text-black font-black flex flex-col items-center justify-between p-1 rounded-xl cursor-pointer text-[11px] shadow-md border border-white";
                        cell.innerHTML = `<span>START</span><div id="token-space-0" class="h-4 flex items-center"></div><span>1번 칸</span>`;
                    } else if (tileNum === totalGameTiles) {
                        cell.id = `tile-${totalGameTiles-1}`; cell.setAttribute('onclick', `clickTile(${totalGameTiles-1})`);
                        cell.className = "bg-emerald-500 text-white font-black flex flex-col items-center justify-between p-1 rounded-xl cursor-pointer text-[11px] shadow-md border border-white/20";
                        cell.innerHTML = `<span>GOAL</span><div id="token-space-${totalGameTiles-1}" class="h-4 flex items-center"></div><span>30번 칸</span>`;
                    } else {
                        let colorBorder = 'border-level1/30 text-level1';
                        if (tileNum > 10 && tileNum <= 20) colorBorder = 'border-level2/30 text-level2';
                        else if (tileNum > 20) colorBorder = 'border-level3/30 text-level3';
                        cell.id = `tile-${tileNum - 1}`; cell.setAttribute('onclick', `clickTile(${tileNum - 1})`);
                        cell.className = `glass border ${colorBorder} flex flex-col items-center justify-between p-1 rounded-xl cursor-pointer hover:bg-white/5 transition-all text-center text-[10px] font-bold`;
                        cell.innerHTML = `<span class="opacity-40 font-mono">${tileNum}</span><div id="token-space-${tileNum - 1}" class="h-3 flex items-center"></div><span class="text-[9px] opacity-70">대화</span>`;
                    }
                    gridContainer.appendChild(cell);
                }
            }
        }

        let isRolling = false;
        function rollDice3D() {
            if (isRolling) return; isRolling = true;
            const cube = document.getElementById('dice-cube'); const btn = document.getElementById('btn-roll');
            btn.disabled = true; cube.className = "cube is-rolling";
            document.getElementById('dice-result-guide').textContent = "주사위 굴리는 중...";

            setTimeout(() => {
                const diceValue = Math.floor(Math.random() * 6) + 1; cube.className = `cube show-${diceValue}`;
                let targetPos = tokenPosition + diceValue;
                if (targetPos >= totalGameTiles) { targetPos = totalGameTiles - 1; }
                tokenPosition = targetPos; updateTokenUI(); openRandomQuestionFromSpot(tokenPosition, diceValue);
                isRolling = false; btn.disabled = false;
            }, 800);
        }

        function updateTokenUI() {
            for (let i = 0; i < totalGameTiles; i++) {
                const space = document.getElementById(`token-space-${i}`); if (space) space.innerHTML = '';
                const tile = document.getElementById(`tile-${i}`); if (tile) tile.classList.remove('bg-white/10', 'border-white', 'scale-105');
            }
            const activeSpace = document.getElementById(`token-space-${tokenPosition}`);
            if (activeSpace) { activeSpace.innerHTML = `<span class="piece-active inline-block w-3.5 h-3.5 rounded-full bg-gradient-to-t from-amber-400 to-yellow-200 border border-white text-[8px] flex items-center justify-center text-black font-black">🏃</span>`; }
            const activeTile = document.getElementById(`tile-${tokenPosition}`);
            if (activeTile) activeTile.classList.add('bg-white/10', 'border-white', 'scale-105');
            const spotText = document.getElementById('current-spot-text');
            if (tokenPosition === 0) spotText.textContent = "START";
            else if (tokenPosition === totalGameTiles - 1) spotText.textContent = "GOAL 🏁";
            else spotText.textContent = `${tokenPosition + 1}번 칸`;
        }

        function clickTile(spotId) { tokenPosition = spotId; updateTokenUI(); openRandomQuestionFromSpot(spotId, null); }

        function openRandomQuestionFromSpot(spotId, diceValue) {
            const panel = document.getElementById('question-panel'); const badge = document.getElementById('panel-badge');
            const qNum = document.getElementById('panel-q-num'); const title = document.getElementById('panel-title');
            const desc = document.getElementById('panel-desc'); const guide = document.getElementById('dice-result-guide');

            if (diceValue) { guide.innerHTML = `주사위 <span class="text-amber-400 font-black text-xs">[ ${diceValue} ]</span> 등장! 다음 칸으로 전진했습니다.`; }
            else { guide.textContent = "말판을 눌러 수동 선택했습니다."; }

            if (spotId === 0) {
                badge.className = "px-2 py-0.5 rounded-full text-[10px] font-black bg-white/10 text-gray-400 uppercase"; badge.textContent = "대기";
                qNum.textContent = "SPACE #01"; title.textContent = "출발 지점입니다! 주사위를 굴려주세요.";
                title.className = "text-sm md:text-lg font-black text-gray-400 text-center break-keep";
                desc.textContent = "ㄹ자 모양 보드판을 돌며 지체들과 이야기를 나눠보세요.";
                panel.style.borderColor = "rgba(255,255,255,0.08)"; return;
            }

            if (spotId === totalGameTiles - 1) {
                badge.className = "px-2 py-0.5 rounded-full text-[10px] font-black bg-emerald-500 text-black uppercase"; badge.textContent = "완주";
                qNum.textContent = "SPACE #30"; title.textContent = "축하합니다! 대화 보드게임 골인 지점에 도달했습니다!";
                title.className = "text-sm md:text-lg font-black text-emerald-400 text-center break-keep";
                desc.textContent = "오늘 나눈 은혜를 가슴에 품고 다 함께 마무리 기도나 박수로 소그룹을 마무리해 보세요.";
                panel.style.borderColor = "#10B981"; return;
            }

            const randIdx = Math.floor(Math.random() * QUESTIONS_POOL.length); const q = QUESTIONS_POOL[randIdx];
            qNum.textContent = `RANDOM CARD #${String(q.id).padStart(2, '0')}`; title.textContent = q.title; desc.textContent = q.desc;
            title.className = "text-sm md:text-lg font-black text-white text-center break-keep";

            if (q.level === 1) {
                badge.className = "px-2 py-0.5 rounded-full text-[10px] font-black bg-level1/20 text-level1 uppercase"; badge.textContent = "LEVEL 1. 아이스브레이킹";
                panel.style.borderColor = "rgba(255,138,138,0.3)";
            } else if (q.level === 2) {
                badge.className = "px-2 py-0.5 rounded-full text-[10px] font-black bg-level2/20 text-level2 uppercase"; badge.textContent = "LEVEL 2. 소통과 가치";
                panel.style.borderColor = "rgba(74,222,128,0.3)";
            } else {
                badge.className = "px-2 py-0.5 rounded-full text-[10px] font-black bg-level3/20 text-level3 uppercase"; badge.textContent = "LEVEL 3. 신앙과 은혜";
                title.className = "text-sm md:text-lg font-black text-amber-200 text-center break-keep"; panel.style.borderColor = "rgba(167,139,250,0.3)";
            }
        }

        function resetGame() {
            if (confirm("게임을 처음 상태로 리셋하시겠습니까?")) { tokenPosition = 0; updateTokenUI(); openRandomQuestionFromSpot(0, null); }
        }

        window.addEventListener('DOMContentLoaded', () => { buildSnakeBoard(); updateTokenUI(); });
    </script>
